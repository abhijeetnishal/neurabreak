# Git attributes for NeuraBreak

# Track large binary model files with Git LFS
*.onnx filter=lfs diff=lfs merge=lfs -text
*.pt   filter=lfs diff=lfs merge=lfs -text
*.pth  filter=lfs diff=lfs merge=lfs -text
*.bin  filter=lfs diff=lfs merge=lfs -text

# Normalise line endings
* text=auto

# Python
*.py text eol=lf
*.pyi text eol=lf

# Scripts — preserve LF on all platforms
*.sh text eol=lf
Makefile text eol=lf

# Config / data files
*.toml text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.txt  text eol=lf

# Windows-specific files keep CRLF
*.ps1  text eol=crlf
*.bat  text eol=crlf
*.iss  text eol=crlf
*.spec text eol=lf

# Images — binary, no LFS (small icons only)
*.png  binary
*.ico  binary
*.icns binary
